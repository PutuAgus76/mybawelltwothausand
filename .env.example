# =============================================================
# .env.example — Our Love Story Website
# =============================================================
# Salin file ini menjadi .env.local lalu isi nilai aslinya.
# JANGAN commit .env.local ke Git!
# =============================================================

# URL publik website kamu (isi setelah deploy ke Vercel)
# Contoh: https://nama-project.vercel.app
# Dipakai untuk metadata OpenGraph
NEXT_PUBLIC_SITE_URL=

# -----------------------------------------------
# SUPABASE
# Dapatkan nilai ini dari: Supabase Dashboard > Project Settings > API
# -----------------------------------------------

# URL project Supabase kamu (aman di client-side, publik)
NEXT_PUBLIC_SUPABASE_URL=

# Anon / Publishable Key (aman di client-side, hanya bisa akses data sesuai RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — RAHASIA! HANYA DIPAKAI DI SERVER (Server Actions / API Routes)
# Key ini melewati semua RLS — JANGAN PERNAH expose ke client/browser.
# Tidak perlu prefix NEXT_PUBLIC_ karena memang hanya untuk server.
# Dapatkan dari: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------
# CLOUDINARY
# Dapatkan dari: Cloudinary Dashboard > Settings > API Keys
# -----------------------------------------------

# Cloud Name (aman di client-side, dipakai next/image remote pattern)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# API Key (dipakai di server untuk upload signature)
CLOUDINARY_API_KEY=

# API Secret — RAHASIA! Hanya dipakai di server untuk generate upload signature
# JANGAN PERNAH expose ke client/browser atau commit ke Git.
CLOUDINARY_API_SECRET=
